{
  "type": "module",
  "license": "Apache-2.0",
  "name": "@sovereignbase/convergent-replicated-list",
  "version": "1.3.7",
  "description": "Convergent Replicated List (CR-List), a delta CRDT for an ordered sequence of entries.",
  "keywords": [
    "crdt",
    "list",
    "replicated",
    "convergent",
    "local-first",
    "distributed-systems",
    "delta-sync",
    "gossip",
    "typescript",
    "sovereignbase"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./wasm": {
      "types": "./wasm/dist/index.d.mts",
      "import": "./wasm/dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "size": "npm run bundle-size && npm run byte-size",
    "bundle-size": "node benchmark/bundle-size/index.js",
    "byte-size": "node benchmark/byte-size/index.js",
    "format": "prettier . --write",
    "build": "tsdown && typedoc",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "stress": "node test/stress/run.mjs",
    "update-readme": "node scripts/update-readme.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.6",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@sovereignbase/frontier-store": "^1.0.0",
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "deno": "^2.8.2",
    "edge-runtime": "^4.0.1",
    "esbuild": "^0.28.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "json-joy": "^18.28.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "terser": "^5.48.0",
    "tsdown": "^0.22.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "unrun": "^0.3.1",
    "wrangler": "^4.98.0",
    "yjs": "^13.6.31",
    "@msgpack/msgpack": "^3.1.3"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovereignbase/convergent-replicated-list.git"
  },
  "bugs": {
    "url": "https://github.com/sovereignbase/convergent-replicated-list/issues"
  },
  "homepage": "https://sovereignbase.dev/convergent-replicated-list"
}
