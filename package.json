{
  "type": "module",
  "license": "Apache-2.0",
  "name": "@sovereignbase/sequencer",
  "version": "0.0.0",
  "description": "World's fastest causality engine for building CRDT's",
  "keywords": [
    "crdt",
    "sequence",
    "replicated",
    "convergent",
    "local-first",
    "distributed-systems",
    "delta-sync",
    "gossip",
    "typescript",
    "sovereignbase"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./wasm": {
      "types": "./wasm/dist/index.d.mts",
      "import": "./wasm/dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "format": "prettier . --write",
    "build": "tsdown && typedoc",
    "build:wasm": "cmake --build --preset wasm-release && cmake --install temp/build/wasm-release --prefix src/typescript/wasm/raw && node -e \"const fs=require('node:fs');const p='src/typescript/wasm/raw/sequencer_wasm.mjs';const b=fs.readFileSync(p);const a=Buffer.from('async function Module');const c=Buffer.from('function Module');if(b.subarray(0,a.length).equals(a))fs.writeFileSync(p,Buffer.concat([c,b.subarray(a.length)]))\"",
    "configure:wasm": "emcmake cmake --preset wasm-release",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "test:stress": "node test/stress/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@msgpack/msgpack": "^3.1.3",
    "@playwright/test": "^1.60.1",
    "@sovereignbase/frontier-store": "^1.0.0",
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "deno": "^2.9.2",
    "edge-runtime": "^4.0.1",
    "esbuild": "^0.28.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "terser": "^5.49.0",
    "tsdown": "^0.22.4",
    "typedoc": "^0.28.20",
    "typescript": "^5.9.3",
    "unrun": "^0.3.1",
    "wrangler": "^4.110.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovereignbase/sequencer.git"
  },
  "bugs": {
    "url": "https://github.com/sovereignbase/sequencer/issues"
  },
  "homepage": "https://sovereignbase.dev/sequencer"
}
