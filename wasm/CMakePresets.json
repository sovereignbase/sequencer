{
  "version": 6,
  "configurePresets": [
    {
      "name": "wasm-release",
      "displayName": "Emscripten Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "wasm-release",
      "configurePreset": "wasm-release"
    }
  ]
}
